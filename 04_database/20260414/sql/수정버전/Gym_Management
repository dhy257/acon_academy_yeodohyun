--운동 정보 입력했을 때 수치가 증가되는 트리거
CREATE OR REPLACE TRIGGER TRG_GYM_SYSTEM_AUTO
AFTER INSERT ON WORKOUT_LOG
FOR EACH ROW
DECLARE
    v_target_muscle VARCHAR2(20);
    v_score NUMBER;
    v_eq_id VARCHAR2(10); -- 기구 ID를 미리 담을 변수
BEGIN
    -- 1. 운동 부위와 기구 ID를 동시에 가져오기
    SELECT Target, equipment_id 
    INTO v_target_muscle, v_eq_id
    FROM EXERCISE
    WHERE Exercise_id = :NEW.Exercise_id;

    -- 2. 근육량 점수 계산 로직
    v_score := CASE 
        WHEN :NEW.Weight * :NEW.Reps * :NEW.Sets < 500 THEN 1
        WHEN :NEW.Weight * :NEW.Reps * :NEW.Sets < 1500 THEN 3
        WHEN :NEW.Weight * :NEW.Reps * :NEW.Sets < 3000 THEN 6
        ELSE 10
    END;

    -- 3. 회원 근육량 업데이트
    IF v_target_muscle = '가슴' THEN
        UPDATE GYM_MEMBER SET CHEST = CHEST + v_score WHERE MEMBER_ID = :NEW.MEMBER_ID;
    ELSIF v_target_muscle = '등' THEN
        UPDATE GYM_MEMBER SET BACK = BACK + v_score WHERE MEMBER_ID = :NEW.MEMBER_ID;
    ELSIF v_target_muscle = '어깨' THEN
        UPDATE GYM_MEMBER SET SHOULDER = SHOULDER + v_score WHERE MEMBER_ID = :NEW.MEMBER_ID;
    ELSIF v_target_muscle = '이두' OR v_target_muscle = '삼두' THEN
        UPDATE GYM_MEMBER SET ARM = ARM + v_score WHERE MEMBER_ID = :NEW.MEMBER_ID;
    ELSIF v_target_muscle = '하체' THEN
        UPDATE GYM_MEMBER SET LEG = LEG + v_score WHERE MEMBER_ID = :NEW.MEMBER_ID;
    END IF;

    -- 4. 기구 사용 횟수 업데이트 
    IF v_eq_id IS NOT NULL THEN
        UPDATE EQUIPMENT 
        SET usage_count = usage_count + 1 
        WHERE equipment_id = v_eq_id;
    END IF;
END;
