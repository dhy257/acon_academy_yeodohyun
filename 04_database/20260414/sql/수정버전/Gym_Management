
--테이블 작성
CREATE TABLE Trainer(
    trainer_id number(4) PRIMARY KEY,
    name varchar2(10),
    Date_of_employment date,       --입사일자
    Personal_History date          --경력
);

CREATE TABLE Gym_Member(

    member_id number(4) primary key,
    trainer_id VARCHAR2(10),
    name varchar2(10),
    age number(3),
    Registration_date date default sysdate,     --등록일
    
    --부위별 근육량 default = 0 
    Chest number(5) default 0,
    Back number(5),
    Arm number(5),
    Shoulder number(5),
    Leg number(5),  
    FOREIGN KEY(trainer_id) REFERENCES Trainer(trainer_id)
);

CREATE TABLE Exercise(
    Exercise_id varchar2(10) PRIMARY KEY, 
    Exercise_name varchar2(20),
    Target varchar2(10),
    Difficulty_Level varchar2(10),  --운동 난이도
    Equipment_needed varchar2(50)  --필요한 장비
    --사용횟수
);

CREATE TABLE Workout_Log(
    Workout_id varchar2(30) PRIMARY KEY,
    member_id varchar2(10),     
    trainer_id VARCHAR2(10),
    Exercise_id varchar2(10),
    Sets number(2),     --운동 세트 수
    Reps number(2),     --반복횟수
    Weight number(3),   --중량
    Exercise_date date default sysdate, --운동한 날짜
    
    FOREIGN KEY(member_id) REFERENCES Gym_Member(member_id),
    FOREIGN KEY(trainer_id) REFERENCES Trainer(trainer_id),
    FOREIGN KEY(Exercise_id) REFERENCES Exercise(Exercise_id)
);
commit;

CREATE TABLE Equipment(
    equipment_id VARCHAR2(10) PRIMARY KEY,
    equipment_name VARCHAR2(50),
    usage_count NUMBER DEFAULT 0,     -- 사용 횟수
    cleaned_yn CHAR(1) DEFAULT 'N'    -- 청소 여부 (Y/N)
);


